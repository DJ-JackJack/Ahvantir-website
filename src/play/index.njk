---
layout: base
title: Play — Ahvantir
description: "Live game session — Foundry VTT and lore reference."
permalink: /play/
---

<div class="play-layout" id="play-layout">

  {# ── Foundry panel ─────────────────────────────────────────── #}
  <div class="play-foundry" id="play-foundry">

    <div class="play-foundry__loading" id="play-loading" aria-live="polite" aria-atomic="true">
      <div class="play-foundry__loading-inner">
        <span class="play-foundry__loading-symbol" aria-hidden="true">⚜</span>
        <p class="play-foundry__loading-text">Connecting to the game…</p>
      </div>
    </div>

    {# src set by JS after auth to avoid premature load #}
    <iframe
      id="play-iframe"
      class="play-iframe"
      title="Foundry VTT game session"
      allowfullscreen
      allow="camera; microphone; fullscreen"
      aria-label="Foundry VTT game session"
    ></iframe>

    <div class="play-no-signal" id="play-no-signal" hidden>
      <div class="play-no-signal__inner">
        <span class="play-no-signal__symbol" aria-hidden="true">✦</span>
        <p class="play-no-signal__title">There is no active game at this time.</p>
        <p class="play-no-signal__sub">The session has ended or the game server is offline. Your DM will announce when the next session opens.</p>
        <p class="play-no-signal__next" id="no-signal-next" hidden></p>
        <a href="/articles/" class="btn btn--ghost">Browse the Lore →</a>
      </div>
    </div>

    <div class="play-mobile-msg" id="play-mobile" hidden>
      <div class="play-mobile-msg__inner">
        <span class="play-mobile-msg__symbol" aria-hidden="true">🎲</span>
        <p class="play-mobile-msg__title">Desktop Required</p>
        <p class="play-mobile-msg__body">Foundry VTT requires a desktop browser to play. Please return on a laptop or desktop computer to join the game session.</p>
        <a href="/articles/" class="btn btn--ghost">Browse the Lore →</a>
      </div>
    </div>

  </div>{# /play-foundry #}

  {# ── Panel divider / toggle ────────────────────────────────── #}
  <button
    class="play-lore-toggle"
    id="play-lore-toggle"
    type="button"
    aria-label="Collapse lore panel"
    aria-expanded="true"
    aria-controls="play-lore"
  >›</button>

  {# ── Lore panel ────────────────────────────────────────────── #}
  <div class="play-lore" id="play-lore" aria-label="Lore reference panel">
    <div class="play-lore-inner">

      {# Tab bar #}
      <div class="lore-panel-header">
        <div class="lore-tabs" role="tablist" aria-label="Panel tabs">
          <button class="lore-tab lore-tab--active" id="tab-search" role="tab"
                  aria-selected="true" aria-controls="lore-search-view" type="button">Search</button>
          <button class="lore-tab" id="tab-notes" role="tab"
                  aria-selected="false" aria-controls="lore-notes-view" type="button">Notes</button>
        </div>
      </div>

      {# Search view #}
      <div id="lore-search-view" class="lore-search-view">
        <div class="lore-search-wrap">
          <label for="lore-search-input" class="sr-only">Search articles</label>
          <input
            type="search"
            id="lore-search-input"
            class="lore-search-input"
            placeholder="Search the archives…"
            autocomplete="off"
            spellcheck="false"
          >
        </div>

        {# Bookmarks — visible when search is empty, hidden while typing #}
        <div id="lore-bookmarks" class="lore-bookmarks" hidden>
          <p class="lore-bookmarks__label">Bookmarked</p>
          <ul id="lore-bookmark-list" class="lore-bookmark-list" role="list" aria-label="Bookmarked articles"></ul>
        </div>

        <ul
          id="lore-results"
          class="lore-results"
          role="list"
          aria-label="Search results"
          aria-live="polite"
        >
          <li class="lore-results__hint">Enter a name or keyword.</li>
        </ul>
      </div>

      {# Article view (hidden until a result is selected) #}
      <div id="lore-article-view" class="lore-article-view" hidden>
        <div class="lore-article-toolbar">
          <button class="lore-back-btn" id="lore-back" type="button">← Back</button>
          <button class="lore-bookmark-btn" id="lore-bookmark-btn" type="button"
                  aria-pressed="false" title="Bookmark this article">☆</button>
        </div>
        <h2 class="lore-article-title" id="lore-article-title"></h2>
        <div class="lore-article-body" id="lore-article-body"></div>
        <a
          class="lore-article-fulllink"
          id="lore-article-link"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
        >Open full article ↗</a>
      </div>

      {# Notes view — wraps both list and editor sub-views #}
      <div id="lore-notes-view" class="lore-notes-view" hidden aria-label="Session notes">

        {# List sub-view #}
        <div id="notes-list-view" class="notes-list-view">
          <div class="notes-toolbar">
            <input
              type="search"
              id="notes-search"
              class="notes-search"
              placeholder="Search notes…"
              autocomplete="off"
              spellcheck="false"
              aria-label="Search your notes"
            >
            <button type="button" id="notes-new-btn" class="notes-new-btn" aria-label="Create new note">+ New</button>
          </div>
          <ul id="notes-cards" class="notes-cards" role="list" aria-label="Your notes" aria-live="polite"></ul>
          <p id="notes-empty" class="notes-empty" hidden>No notes yet — hit <strong>+ New</strong> to start one.</p>
          <p id="notes-no-results" class="notes-empty" hidden>No notes match your search.</p>
        </div>

        {# Editor sub-view #}
        <div id="notes-editor-view" class="notes-editor-view" hidden>
          <div class="notes-editor-toolbar">
            <button type="button" id="notes-back-btn" class="notes-back-btn">← Notes</button>
            <p id="notes-save-status" class="notes-save-status" aria-live="polite" aria-atomic="true"></p>
            <button type="button" id="notes-delete-btn" class="notes-delete-btn">Delete</button>
          </div>
          <input
            type="text"
            id="notes-title-input"
            class="notes-title-input"
            placeholder="Title (optional)"
            aria-label="Note title"
            spellcheck="true"
            maxlength="120"
          >
          <textarea
            id="notes-content-input"
            class="notes-content-textarea"
            placeholder="Write your note…"
            aria-label="Note content"
            spellcheck="true"
          ></textarea>
        </div>

      </div>

    </div>
  </div>{# /play-lore #}

</div>{# /play-layout #}

{# Session schedule — visible by scrolling below the panels #}
<section class="session-schedule" id="session-schedule" aria-label="Session schedule">
  <div class="session-schedule__inner">
    <h2 class="session-schedule__heading">Session Schedule</h2>
    <div id="schedule-list" class="schedule-list" aria-live="polite" aria-busy="true"></div>
  </div>
</section>

{# Article index for client-side search — embedded at build time #}
<script type="application/json" id="play-article-data">[{%- for article in collections.allArticles -%}{%- if not loop.first -%},{%- endif -%}{"title":{{ article.data.title | jsonscript | safe }},"description":{{ (article.data.description or "") | stripWikilinks | jsonscript | safe }},"url":"{{ article.url }}","tags":{{ (article.data.tags or []) | jsonscript | safe }},"body":{{ ((article.templateContent or "") | striptags) | jsonscript | safe }}}{%- endfor -%}]</script>

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.108.1/dist/umd/supabase.min.js" integrity="sha384-UQ9Ztz63gzT2JZCuDRkNXV8RP/gXxdPUuM9LKlz2BzqGx9xFYNAK8yAEgbfZHs7P" crossorigin="anonymous"></script>
<script src="/assets/js/player.js"></script>
<script src="/assets/js/play.js"></script>
{% endblock %}
