---
layout: base
title: Timeline
description: "A chronological record of Ahvantir's history."
permalink: /timeline/
---

<div class="page-header">
  <div class="container">
    <h1 class="page-title">The Historical Record</h1>
    <p class="page-lead">Events from the founding era to the present day.</p>
  </div>
</div>

<div class="container timeline-container">

  {% if collections.timeline.length %}

  {% set yearGroups = collections.timeline | groupByField("timeline_year") %}

  <div class="tl-accordion" role="list">
    {% for group in yearGroups %}
    <details class="tl-year" role="listitem">
      <summary class="tl-year__header">
        <span class="tl-year__chevron" aria-hidden="true">›</span>
        <span class="tl-year__label">
          {%- if group.key < 0 -%}
            {{ 0 - group.key }} Pre-Founding
          {%- elif group.key == 0 -%}
            The Founding &mdash; Year 0 MC
          {%- else -%}
            Year {{ group.key }} MC
          {%- endif -%}
        </span>
        <span class="tl-year__count">{{ group.items.length }}</span>
      </summary>
      <ul class="tl-entries" role="list">
        {% for article in group.items %}
        <li class="tl-entry">
          <span class="tl-entry__dot" aria-hidden="true"></span>
          <div class="tl-entry__body">
            <a class="tl-entry__title" href="{{ article.url }}">{{ article.data.title }}</a>
            {% if article.data.timeline_date %}
            <span class="tl-entry__date">{{ article.data.timeline_date }}</span>
            {% endif %}
            {% if article.data.description %}
            <p class="tl-entry__desc">{{ article.data.description | stripWikilinks }}</p>
            {% endif %}
          </div>
        </li>
        {% endfor %}
      </ul>
    </details>
    {% endfor %}
  </div>

  {% else %}

  <div class="empty-state">
    <div class="ornament" aria-hidden="true"><span class="ornament__symbol">✦</span></div>
    <p>No timeline entries yet. Add <code>timeline_year</code> to article frontmatter to populate this page.</p>
  </div>

  {% endif %}

</div>
