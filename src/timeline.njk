---
layout: base
title: Timeline
description: "A chronological record of Ahvantir's history."
permalink: /timeline/
---

<div class="page-header">
  <div class="container">
    <h1 class="page-title">The Historical Record</h1>
    <p class="page-lead">Events from the founding era to the present day.</p>
  </div>
</div>

{% if collections.timeline.length %}

<div class="timeline-h-wrap">
  <div class="timeline-h" id="timeline-h" aria-label="Historical timeline">
    <div class="timeline-h__track"></div>
    <div class="timeline-h__items">
      {% for article in collections.timeline %}
      <div class="timeline-h__entry {% if loop.index0 % 2 == 0 %}timeline-h__entry--above{% else %}timeline-h__entry--below{% endif %}"
           data-year="{{ article.data.timeline_year }}">
        <div class="timeline-h__card">
          <a class="timeline-h__title" href="{{ article.url }}">{{ article.data.title }}</a>
          {% if article.data.description %}
          <p class="timeline-h__snippet">{{ article.data.description }}</p>
          {% endif %}
        </div>
        <div class="timeline-h__dot"></div>
        <div class="timeline-h__date">{{ article.data.timeline_date or article.data.timeline_year }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
  <p class="timeline-h__hint" aria-hidden="true">⟵ &nbsp; drag or scroll to travel through time &nbsp; ⟶</p>
</div>

{% else %}

<div class="container">
  <div class="empty-state">
    <div class="ornament" aria-hidden="true"><span class="ornament__symbol">✦</span></div>
    <p>No timeline entries yet. Add <code>timeline_year</code> to article frontmatter to populate this page.</p>
  </div>
</div>

{% endif %}

{% block scripts %}
<script src="/assets/js/timeline.js"></script>
{% endblock %}
