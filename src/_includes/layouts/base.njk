<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="Content-Security-Policy" content="default-src 'none'; script-src 'self' https://cdn.jsdelivr.net; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src https://fonts.gstatic.com; img-src https: data: blob:; connect-src 'self' https://fbfqeijisvckwmkqzjtd.supabase.co wss://fbfqeijisvckwmkqzjtd.supabase.co https://fonts.googleapis.com https://fonts.gstatic.com https://play-tunnel.ahvantir.world; worker-src 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; frame-src https://play-tunnel.ahvantir.world">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}{{ meta.site.title }}</title>
  <meta name="description" content="{{ (description or meta.site.description) | stripWikilinks }}">
  <meta name="generator" content="Eleventy">
  <meta name="supabase-url" content="{{ meta.supabase.url }}">
  <meta name="supabase-anon-key" content="{{ meta.supabase.anonKey }}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>

  <a href="#main-content" class="skip-link">Skip to content</a>

  <div class="grain" aria-hidden="true"></div>

  <header class="site-header">
    <nav class="nav" aria-label="Main navigation">
      <a href="/" class="nav__home" aria-label="Ahvantir home">
        <span class="nav__sigil" aria-hidden="true">⚜</span>
        <span class="nav__title">{{ meta.site.title }}</span>
      </a>

      <ul class="nav__links" id="nav-links" role="list">
        <li><a href="/articles/">Articles</a></li>
        <li><a href="/timeline/">Timeline</a></li>
        <li><a href="/cosmology/">Cosmology</a></li>
        <li><a href="/map/">World Map</a></li>
        <li><a href="/graph/">Relations</a></li>
        <li><a href="/recently-added/">Recent</a></li>
        <li><a href="/player/hall-of-heroes/">Hall of Heroes</a></li>
        <li hidden id="nav-play-item"><a href="/play/" class="nav__player-link">Play</a></li>
        <li><a href="/search/" class="nav__search-link">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          Search
        </a></li>
        <li><a href="/player/dashboard/" class="nav__player-link">Player</a></li>
        <li><a href="/player/messages/" class="nav__player-link nav__messages-link">
          Messages<span class="nav-badge" id="nav-msg-badge" hidden aria-label="unread messages"></span>
        </a></li>
        <li hidden id="nav-signout-item"><button class="nav__signout" id="nav-signout" type="button">Sign Out</button></li>
        <li class="nav__theme-item">
          <button class="nav__theme-toggle" id="theme-toggle" type="button" aria-label="Switch to dark mode">
            <svg class="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            <svg class="icon-sun"  width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          </button>
        </li>
      </ul>
    </nav>
  </header>

  <main id="main-content">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="ornament" aria-hidden="true">
      <span class="ornament__symbol">✦</span>
    </div>
    <p class="site-footer__tagline">
      These records were compiled in the city of <em>Aru'Mas</em>,<br>
      in the Third Era of the world called Ahvantir.
    </p>
    <p class="site-footer__credits">
      A homebrew D&amp;D setting by <strong>Krys</strong> &mdash; M4st3r_0f_G4m3s
    </p>
  </footer>

  <script src="/assets/js/main.js"></script>
  {% block scripts %}{% endblock %}
</body>
</html>
