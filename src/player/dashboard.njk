---
layout: base
title: My Portal
description: "Your Ahvantir player dashboard."
permalink: /player/dashboard/
---

<div class="page-header">
  <div class="container">
    <h1 class="page-title" id="dash-greeting">Player Dashboard</h1>
    <p class="page-lead">Your characters, your secrets, your story.</p>
  </div>
</div>

<div class="player-page container" id="player-app">
  <p class="player-loading">Loading…</p>
</div>

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="/assets/js/player.js"></script>
<script>
(function () {
  'use strict';
  var db = window.__supabase;
  var profile = null;

  document.addEventListener('DOMContentLoaded', async function () {
    var session = await window.requireAuth(true);
    if (!session) return;

    profile = await window.getProfile();
    if (!profile) return;

    var greeting = document.getElementById('dash-greeting');
    if (greeting) greeting.textContent = 'Welcome, ' + profile.display_name;

    await loadDashboard();
  });

  async function loadDashboard() {
    var app = document.getElementById('player-app');

    var charsResult = await db
      .from('characters')
      .select('id, is_public, data')
      .eq('player_id', profile.id)
      .order('created_at', { ascending: false });

    var notesResult = await db
      .from('campaign_notes')
      .select('id, title, updated_at')
      .eq('player_id', profile.id)
      .order('updated_at', { ascending: false })
      .limit(3);

    var chars = charsResult.data || [];
    var recentNotes = notesResult.data || [];

    var charCards = chars.length
      ? chars.map(function (c) {
          var d = c.data || {};
          var name = d.name || '(Unnamed)';
          var sub  = [d.race, d.class_name].filter(Boolean).join(' ');
          var level = d.level ? ' · Level ' + d.level : '';
          return '<a href="/player/character/?id=' + c.id + '" class="player-card">' +
            '<div class="player-card__name">' + esc(name) + '</div>' +
            (sub ? '<div class="player-card__sub">' + esc(sub) + esc(level) + '</div>' : '') +
            '<div class="player-card__badges">' +
              (c.is_public
                ? '<span class="badge badge--teal">Public</span>'
                : '<span class="badge">Private</span>') +
            '</div>' +
          '</a>';
        }).join('')
      : '<p class="dash-empty">No characters yet. <a href="/player/character/?new=1">Create your first one.</a></p>';

    var notesList = recentNotes.length
      ? '<ul class="dash-notes-list">' +
          recentNotes.map(function (n) {
            return '<li><a href="/player/notes/" class="dash-notes-link">' + esc(n.title || 'Untitled') + '</a></li>';
          }).join('') +
        '</ul>'
      : '<p class="dash-empty">No notes yet. <a href="/player/notes/">Start writing.</a></p>';

    app.innerHTML =
      '<section class="dash-section">' +
        '<div class="dash-section__header">' +
          '<h2 class="dash-section__title">My Characters</h2>' +
          '<a href="/player/character/?new=1" class="btn btn--primary btn--sm">+ New Character</a>' +
        '</div>' +
        '<div class="player-card-grid">' + charCards + '</div>' +
      '</section>' +

      '<section class="dash-section">' +
        '<div class="dash-section__header">' +
          '<h2 class="dash-section__title">Campaign Notes</h2>' +
          '<a href="/player/notes/" class="btn btn--ghost btn--sm">All Notes</a>' +
        '</div>' +
        notesList +
      '</section>' +

      '<div class="dash-footer">' +
        '<button class="btn btn--ghost btn--sm" onclick="window.playerSignOut()" type="button">Sign Out</button>' +
      '</div>';
  }

  function esc(str) {
    return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
})();
</script>
{% endblock %}
