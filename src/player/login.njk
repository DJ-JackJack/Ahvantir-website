---
layout: base
title: Player Portal
description: "Sign in or register for the Ahvantir player portal."
permalink: /player/login/
---

<div class="player-page player-page--centered">
  <div class="auth-card">
    <div class="auth-card__sigil" aria-hidden="true">⚜</div>
    <h1 class="auth-card__title">Player Portal</h1>
    <p class="auth-card__subtitle">Access your characters and campaign notes.</p>

    <div class="auth-tabs" role="tablist">
      <button class="auth-tab auth-tab--active" role="tab" data-tab="signin" type="button">Sign In</button>
      <button class="auth-tab" role="tab" data-tab="register" type="button">Register</button>
    </div>

    <div id="auth-status" class="auth-status" aria-live="polite" style="display:none"></div>

    <form id="form-signin" class="auth-form" novalidate>
      <label class="form-label">
        Email
        <input class="form-input" type="email" id="signin-email" autocomplete="email" required>
      </label>
      <label class="form-label">
        Password
        <input class="form-input" type="password" id="signin-password" autocomplete="current-password" required>
      </label>
      <button class="btn btn--primary btn--full" type="submit">Sign In</button>
    </form>

    <form id="form-register" class="auth-form" style="display:none" novalidate>
      <label class="form-label">
        Display Name
        <input class="form-input" type="text" id="reg-name" autocomplete="name" required>
      </label>
      <label class="form-label">
        Email
        <input class="form-input" type="email" id="reg-email" autocomplete="email" required>
      </label>
      <label class="form-label">
        Password <small class="form-label__hint">(min 8 characters)</small>
        <input class="form-input" type="password" id="reg-password" autocomplete="new-password" required minlength="8">
      </label>
      <button class="btn btn--primary btn--full" type="submit">Create Account</button>
    </form>
  </div>
</div>

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.108.1/dist/umd/supabase.min.js" integrity="sha384-UQ9Ztz63gzT2JZCuDRkNXV8RP/gXxdPUuM9LKlz2BzqGx9xFYNAK8yAEgbfZHs7P" crossorigin="anonymous"></script>
<script src="/assets/js/player.js"></script>
<script src="/assets/js/player-login.js"></script>
{% endblock %}
