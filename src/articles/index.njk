---
layout: base
title: Articles
description: "The full Ahvantir lore index — browse all articles by category and tag."
permalink: /articles/
---

<div class="page-header">
  <div class="container">
    <h1 class="page-title">Articles</h1>
    <p class="page-lead">{{ collections.allArticles.length }} {{ "article" if collections.allArticles.length == 1 else "articles" }} across {{ meta.categories.length }} subjects.</p>
  </div>
</div>

<div class="container articles-page">

  <div class="articles-controls">
    <input
      type="search"
      id="article-filter"
      class="filter-input"
      placeholder="Filter by title or tag…"
      aria-label="Filter articles"
    >
    <div class="filter-tags" role="group" aria-label="Filter by category">
      <button class="filter-btn active" data-filter="all">All</button>
      {% for cat in meta.categories %}
      <button class="filter-btn" data-filter="{{ cat.slug }}">{{ cat.label }}</button>
      {% endfor %}
    </div>
  </div>

  {% for cat in meta.categories %}
  {% set catArticles = [] %}
  {% for article in collections.allArticles %}
    {% if article.data.category == cat.slug %}
      {% set catArticles = catArticles.concat([article]) %}
    {% endif %}
  {% endfor %}
  {% if catArticles.length %}
  <section class="articles-section" id="{{ cat.slug }}" data-category="{{ cat.slug }}">
    <h2 class="articles-section__title">
      <span aria-hidden="true">{{ cat.icon }}</span> {{ cat.label }}
    </h2>
    <div class="article-grid">
      {% for article in catArticles %}
      <a href="{{ article.url }}"
         class="article-card"
         data-category="{{ article.data.category }}"
         data-tags="{{ article.data.tags | join(' ') }}"
         data-tag-slugs="{{ article.data.tags | joinSlugs }}"
         data-title="{{ article.data.title | lower }}">
        <h3 class="article-card__title">{{ article.data.title }}</h3>
        {% if article.data.description %}
        <p class="article-card__desc">{{ article.data.description | stripWikilinks }}</p>
        {% endif %}
        {% if article.data.tags and article.data.tags.length %}
        <div class="article-card__tags">
          {% for tag in article.data.tags %}
          <span class="tag tag--sm">{{ tag }}</span>
          {% endfor %}
        </div>
        {% endif %}
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}
  {% endfor %}

  {% set uncategorized = [] %}
  {% for article in collections.allArticles %}
    {% if not article.data.category %}
      {% set uncategorized = uncategorized.concat([article]) %}
    {% endif %}
  {% endfor %}
  {% if uncategorized.length %}
  <section class="articles-section" id="uncategorized" data-category="uncategorized">
    <h2 class="articles-section__title">Uncategorized</h2>
    <div class="article-grid">
      {% for article in uncategorized %}
      <a href="{{ article.url }}" class="article-card" data-title="{{ article.data.title | lower }}">
        <h3 class="article-card__title">{{ article.data.title }}</h3>
        {% if article.data.description %}
        <p class="article-card__desc">{{ article.data.description | stripWikilinks }}</p>
        {% endif %}
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}

</div>

{% block scripts %}
<script src="/assets/js/articles-filter.js"></script>
{% endblock %}
